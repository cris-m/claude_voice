redis-data/


# Terraform
terraform.tfvars          # Local terraform vars (never commit)
terraform.tfvars.json     # JSON terraform vars (never commit)
*.tfstate                 # State files (never commit)
*.tfstate.backup          # State backups (never commit)
.terraform/               # Terraform working directory
.terraform.lock.hcl       # Lock file (can commit in some projects)
override.tf               # Override files (local only)
override.tf.json          # Override files JSON (local only)
crash.log                 # Crash logs
crash.*.log